# Raw data (large, downloadable from source or on external HD)
# The data/ subdirs are symlinks to /Volumes/TAWoolff EXT/data/
# Symlinks themselves are tracked; their contents are ignored below.
data/fbx/**
data/poses/**
data/mocap/**
data/sprites/**
data/live2d/**
data/vroid/**
data/psd/**
data/preprocessed/**
data/nova_human/**
data/Universal Base Characters*/

# Generated output (reproducible)
output/

# Keep READMEs, label files, and metadata inside ignored directories
!data/fbx/README.md
!data/poses/README.md
!data/mocap/README.md
!data/sprites/README.md
!data/live2d/README.md
!data/live2d/labels/
!data/live2d/labels/**
!data/vroid/README.md
!data/vroid/labels/
!data/vroid/labels/**
!data/psd/README.md
!data/preprocessed/*/
!data/preprocessed/*/README.md
!data/preprocessed/stdgen/stdgen_to_strata.json

# ONNX model weights (downloaded, not tracked)
models/*.onnx
models/*.zip

# Cloned dependencies (research notebooks)
deps/

